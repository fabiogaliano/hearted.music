{
	"name": "hearted-extension",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bun run scripts/build.ts",
		"dev": "bun run scripts/build.ts --watch",
		"ext:store:firefox": "bun run scripts/build.ts --target=firefox --store",
		"ext:lint:firefox": "web-ext lint --source-dir=dist/firefox",
		"test": "vitest run",
		"test:live": "vitest run -c vitest.live.config.ts",
		"test:watch": "vitest"
	},
	"dependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/chrome": "^0.0.304",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"esbuild": "^0.25.0",
		"typescript": "^5.7.0",
		"vitest": "^4.0.18",
		"web-ext": "^10.3.0"
	}
}
