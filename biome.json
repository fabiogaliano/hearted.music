{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**/src/**/*",
			"**/index.html",
			"**/vite.config.ts",
			"**/package.json",
			"**/biome.json",
			"!v1_hearted_brand",
			"!scripts/matching-lab",
			"!**/src/routeTree.gen.ts",
			"!**/src/styles.css",
			"!**/src/features/liked-songs/components/variants",
			"!**/.playwright",
			"!**/.claude"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noDeprecatedImports": "error"
			},
			"style": {
				"noProcessEnv": "error"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"overrides": [
		{
			"includes": ["**/__tests__/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					},
					"complexity": {
						"useArrowFunction": "off"
					},
					"style": {
						"noProcessEnv": "off"
					}
				}
			}
		},
		{
			"includes": ["**/src/env.ts", "**/src/worker/**", "**/vite.config.ts"],
			"linter": {
				"rules": {
					"style": {
						"noProcessEnv": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/stories/**",
				"**/src/lib/integrations/providers/adapters/local.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/src/**/playground/**",
				"**/src/**/_ProdPrimitives.tsx",
				"**/src/stories/**"
			],
			"linter": {
				"enabled": false
			}
		}
	]
}
