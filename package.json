{
	"name": "hearted-app",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.14",
	"scripts": {
		"prepare": "lefthook install",
		"dev": "ML_PROVIDER=local vite dev",
		"dev:worker": "bun --preload ./src/worker/instrument.ts src/worker/index.ts",
		"dev:embeddings": "bun scripts/dev/dev-embedding-sidecar.ts",
		"dev:brand": "cd ../v1_hearted_brand && bun run dev",
		"dev:stripe": "stripe listen --forward-to localhost:3100/webhooks/stripe",
		"dev:all": "concurrently -n app,worker,ml -c blue,green,magenta --kill-others-on-fail \"bun run dev\" \"bun run dev:worker\" \"bun run dev:embeddings\"",
		"dev:monetization": "concurrently -n app,worker,ml,brand,stripe -c blue,green,magenta,yellow,cyan --kill-others-on-fail \"bun run dev\" \"bun run dev:worker\" \"bun run dev:embeddings\" \"bun run dev:brand\" \"bun run dev:stripe\"",
		"build": "vite build",
		"preview": "vite preview",
		"test": "VITEST_MAX_WORKERS=2 vitest run",
		"test:fast": "vitest run",
		"test:live": "VITEST_LIVE=true vitest run",
		"test:e2e": "bun tests/e2e/auth.e2e.ts",
		"typecheck": "tsgo --noEmit",
		"typecheck:worker": "tsgo -p src/worker/tsconfig.json --noEmit",
		"typecheck:legacy": "tsc --noEmit",
		"typecheck:legacy:worker": "tsc -p src/worker/tsconfig.json --noEmit",
		"check": "biome check",
		"lint": "biome lint",
		"format": "biome format",
		"gen:types": "supabase gen types typescript --db-url postgresql://postgres:postgres@127.0.0.1:54322/postgres > src/lib/data/database.types.ts",
		"fixtures": "bun src/stories/fixtures/build-fixtures.ts",
		"lyrics:validate": "PARSER_VALIDATION=true vitest run lyrics-service.integration",
		"voice-audit": "bun scripts/voice-audit/cli.ts",
		"reset:onboarding": "bun scripts/ops/reset-onboarding.ts",
		"grant:liked-access": "bun scripts/ops/grant-liked-song-access.ts",
		"prod:sql": "bun scripts/db/prod.ts sql",
		"prod:rest": "bun scripts/db/prod.ts rest",
		"ext:build": "bun extensions/scripts/build.ts",
		"ext:dev": "bun extensions/scripts/build.ts --watch",
		"ext:store": "bun extensions/scripts/build.ts --store",
		"ext:build:chromium": "bun extensions/scripts/build.ts --target=chromium",
		"ext:build:firefox": "bun extensions/scripts/build.ts --target=firefox",
		"ext:dev:firefox": "bun extensions/scripts/build.ts --target=firefox --watch",
		"ext:store:firefox": "bun extensions/scripts/build.ts --target=firefox --store",
		"ext:lint:firefox": "bunx web-ext lint --source-dir extensions/dist/firefox",
		"hash:sync": "bun scripts/spotify-hash-sync/sync.ts",
		"backfill:release-year": "bun scripts/spotify-hash-sync/backfill-release-year.ts",
		"cp:api": "bun --watch --preload ./control-panel/server/env-bootstrap.ts control-panel/server/index.ts",
		"cp:web": "vite --config control-panel/vite.config.ts",
		"control-panel": "concurrently -n cp-api,cp-web -c magenta,cyan --kill-others-on-fail \"bun run cp:api\" \"bun run cp:web\"",
		"ladle": "ladle serve",
		"ladle:build": "ladle build",
		"deploy": "RELEASE=true bun run build && wrangler deploy",
		"deploy:secrets": "bun scripts/ops/env-to-secrets.ts .env.cloud --mode released && wrangler secret bulk < prod-secrets.json"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.47",
		"@ai-sdk/google": "^3.0.31",
		"@ai-sdk/google-vertex": "^4",
		"@ai-sdk/openai": "^3.0.34",
		"@gsap/react": "^2.1.2",
		"@huggingface/inference": "^4.13.13",
		"@huggingface/transformers": "^4.2.0",
		"@neondatabase/serverless": "^1.0.2",
		"@number-flow/react": "^0.6.0",
		"@opentelemetry/resources": "^2.7.1",
		"@opentelemetry/sdk-node": "^0.218.0",
		"@phosphor-icons/react": "^2.1.10",
		"@posthog/ai": "^7.19.2",
		"@posthog/react": "^1.9.1",
		"@sentry/bun": "^10.53.1",
		"@sentry/cloudflare": "^10.53.1",
		"@sentry/react": "^10.53.1",
		"@sentry/tanstackstart-react": "^10.53.1",
		"@supabase/supabase-js": "^2.97.0",
		"@t3-oss/env-core": "^0.13.10",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.163.2",
		"@tanstack/react-router-ssr-query": "^1.163.2",
		"@tanstack/react-start": "^1.163.2",
		"@tanstack/zod-adapter": "^1.163.2",
		"ai": "^6.0.101",
		"better-auth": "^1.5.2",
		"better-result": "github:fabiogaliano/better-result",
		"clsx": "^2.1.1",
		"css-select": "^6.0.0",
		"domhandler": "^5.0.3",
		"drizzle-orm": "^0.45.1",
		"framer-motion": "^12.34.3",
		"gsap": "^3.14.2",
		"htmlparser2": "^10.1.0",
		"obscenity": "^0.4.6",
		"postgres": "^3.4.8",
		"posthog-node": "^5.35.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"resend": "^6.9.3",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.3.0",
		"transliteration": "^2.6.1",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@cloudflare/vite-plugin": "^1.37.2",
		"@ladle/react": "npm:@fabiogaliano/ladle-react@^5.3.0",
		"@playwright/cli": "^0.1.13",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/devtools-vite": "^0.7.0",
		"@tanstack/react-devtools": "^0.9.6",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@tanstack/react-router-devtools": "^1.163.2",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/bun": "^1.3.10",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260524.1",
		"@vitejs/plugin-react": "^6.0.2",
		"concurrently": "^9.2.1",
		"esbuild": "^0.27.3",
		"jsdom": "^27.0.0",
		"lefthook": "^2.1.6",
		"react-scan": "^0.5.3",
		"tsx": "^4.22.2",
		"typescript": "^6.0.3",
		"uipane": "github:fabiogaliano/uipane",
		"vite": "^8.0.13",
		"vitest": "^4.1.6",
		"wrangler": "^4.93.0"
	},
	"overrides": {
		"ws": "8.21.0",
		"dompurify": "^3.4.7"
	}
}
