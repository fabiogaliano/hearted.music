{
	"name": "hearted-app",
	"private": true,
	"type": "module",
	"scripts": {
		"prepare": "lefthook install",
		"dev": "concurrently -n web,worker -c cyan,magenta --kill-others \"ML_PROVIDER=local vite dev\" \"sleep 3 && bun src/worker/index.ts\"",
		"dev:web": "ML_PROVIDER=local vite dev",
		"dev:worker": "bun src/worker/index.ts",
		"dev:clean": "VITE_DEVTOOLS=false vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"deploy": "bun run build && wrangler deploy",
		"deploy:secrets:waitlist": "bun scripts/env-to-secrets.ts .env.cloud --mode waitlist && wrangler secret bulk < prod-secrets.json && rm prod-secrets.json",
		"deploy:secrets:released": "bun scripts/env-to-secrets.ts .env.cloud --mode released && wrangler secret bulk < prod-secrets.json && rm prod-secrets.json",
		"format": "biome format",
		"lint": "biome lint",
		"check": "biome check",
		"gen:types": "supabase gen types typescript --local > src/lib/data/database.types.ts",
		"typecheck": "tsc --noEmit",
		"lyrics:snapshot": "bun src/lib/services/lyrics/__tests__/generate-snapshots.ts",
		"lyrics:validate": "PARSER_VALIDATION=true vitest run lyrics-service.integration",
		"dev:embeddings": "bun scripts/embedding-server.ts",
		"ext:build": "bun extension/scripts/build.ts",
		"ext:dev": "bun extension/scripts/build.ts --watch",
		"ext:store": "bun extension/scripts/build.ts --store"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.47",
		"@ai-sdk/google": "^3.0.31",
		"@ai-sdk/openai": "^3.0.34",
		"@cloudflare/vite-plugin": "^1.25.5",
		"@fostertheweb/spotify-web-sdk": "^1.3.0",
		"@gsap/react": "^2.1.2",
		"@huggingface/inference": "^4.13.13",
		"@huggingface/transformers": "^3.8.1",
		"@neondatabase/serverless": "^1.0.2",
		"@number-flow/react": "^0.6.0",
		"@supabase/supabase-js": "^2.97.0",
		"@t3-oss/env-core": "^0.13.10",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-devtools": "^0.9.6",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@tanstack/react-router": "^1.163.2",
		"@tanstack/react-router-devtools": "^1.163.2",
		"@tanstack/react-router-ssr-query": "^1.163.2",
		"@tanstack/react-start": "^1.163.2",
		"@tanstack/router-plugin": "^1.163.2",
		"@tanstack/zod-adapter": "^1.163.2",
		"ai": "^6.0.101",
		"better-auth": "^1.5.2",
		"better-result": "^2.7.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"css-select": "^6.0.0",
		"domhandler": "^5.0.3",
		"domutils": "^3.2.2",
		"drizzle-orm": "^0.45.1",
		"framer-motion": "^12.34.3",
		"gsap": "^3.14.2",
		"htmlparser2": "^10.1.0",
		"lucide-react": "^0.575.0",
		"postgres": "^3.4.8",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"resend": "^6.9.3",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"vite-tsconfig-paths": "^6.1.1",
		"wretch": "^3.0.6",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@esbuild/darwin-arm64": "0.27.3",
		"@tanstack/devtools-vite": "^0.5.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/bun": "^1.3.10",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"concurrently": "^9.2.1",
		"esbuild": "^0.27.3",
		"jsdom": "^27.0.0",
		"lefthook": "^2.1.1",
		"react-scan": "^0.5.3",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.0.5",
		"web-vitals": "^5.1.0",
		"wrangler": "^4.68.1"
	}
}
