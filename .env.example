# ─── SUPABASE ───────────────────────────────────────────────────────────────
# Local development (supabase start)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── BETTER AUTH ────────────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
BETTER_AUTH_SECRET=your_64_char_hex_secret_here

# Your app URL (where Better Auth endpoints are served)
# Must match the origin Vite serves on (default: http://127.0.0.1:5173)
BETTER_AUTH_URL=http://127.0.0.1:5173

# Supabase Postgres connection string
# Find at: Supabase Dashboard > Settings > Database > Connection String
# App traffic can use direct or pooler connections. Worker backups must use a
# direct connection or the session pooler on port 5432, never the transaction
# pooler on 6543.
DATABASE_URL=postgresql://postgres:your_password@127.0.0.1:54322/postgres

# ─── SOCIAL AUTH PROVIDERS ──────────────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create "OAuth 2.0 Client ID" (Web application type)
# Add redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── SPOTIFY API (optional) ────────────────────────────────────────────────
# Only needed for album art fetching via Client Credentials grant.
# App works without these — album art will gracefully degrade.
# Get at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ─── ML / ANALYSIS PROVIDERS ───────────────────────────────────────────────
# At least one LLM provider needed for song analysis
# DeepInfra: https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=your_deepinfra_key

# Hugging Face (fallback): https://huggingface.co/settings/tokens
HF_TOKEN=your_hf_token

# Provider selection (auto-detected from available keys if omitted)
ML_PROVIDER=deepinfra

# ─── LLM PROVIDERS (optional) ──────────────────────────────────────────────
# Structured content analysis via the Vercel AI SDK. Analysis degrades
# gracefully when no provider is configured — defaults to Vertex AI.
#
# Vertex AI (default) — bills the GCP project so it draws Cloud credits.
# Authenticates via Application Default Credentials, not an API key:
#   • Local:     gcloud auth application-default login   (then set the project)
#   • Container: paste the service-account JSON into GOOGLE_APPLICATION_CREDENTIALS_JSON
GOOGLE_VERTEX_PROJECT=your_gcp_project_id
GOOGLE_VERTEX_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# AI Studio Gemini (alternative, key-based) — first match wins;
# https://aistudio.google.com/apikey. Used only when provider is set to "google".
# GEMINI_API_KEY=your_gemini_api_key
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ─── ENRICHMENT SERVICES (optional) ────────────────────────────────────────
# Genius lyrics: https://genius.com/api-clients
GENIUS_CLIENT_TOKEN=your_genius_client_token

# Last.fm genres: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key

# ─── CHROME EXTENSION ─────────────────────────────────────────────────────
# Extension ID for PING/PONG detection during onboarding.
# Published extension ID (use a different ID when testing an unpacked local build).
VITE_CHROME_EXTENSION_ID=ohaaafmgbbfohhjhogonolonpjhhfohk

# ─── BILLING ───────────────────────────────────────────────────────────────
# Set to true to enable Stripe billing integration
BILLING_ENABLED=false

# Billing service base URL (required when BILLING_ENABLED=true)
# BILLING_SERVICE_URL=https://billing.example.com

# HMAC shared secret for app <-> billing service auth (required when BILLING_ENABLED=true)
# BILLING_SHARED_SECRET=your_shared_secret_here

# Set to true to show quarterly plan option in the UI
QUARTERLY_PLAN_ENABLED=false

# ─── APP CONFIG (optional) ─────────────────────────────────────────────────
SERVER_URL=
VITE_APP_TITLE=

# ─── WORKER DB BACKUPS (optional runtime env) ─────────────────────────────
# Disabled by default. In production, set these on the Coolify worker.
BACKUP_ENABLED=false
# Recommended: keep backups on a direct 5432 connection even if app traffic
# later moves to a pooler.
BACKUP_DATABASE_URL=
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE_HOUR_UTC=3
BACKUP_SCHEDULE_MINUTE_UTC=0
BACKUP_FILE_PREFIX=hearted

# ─── SENTRY (optional) ─────────────────────────────────────────────────────
# Client-side DSN. Bundled into the browser bundle by Vite at build time.
# Leave empty in dev to keep Sentry silent locally.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# Sentry organization slug — the subdomain in your Sentry URL
# (https://<slug>.sentry.io/). Enables PostHog ⇄ Sentry cross-links: every
# Sentry event picks up the PostHog session URL + distinct ID, and PostHog
# exception events deep-link back to the Sentry issue. No-op when empty.
VITE_SENTRY_ORG_SLUG=

# Server-side DSN for Cloudflare Workers. Set via `wrangler secret put SENTRY_DSN`
# in production, or via .dev.vars locally. NOT loaded from this file at runtime.
# SENTRY_DSN=

# Build-time auth token for source map upload. CI only — never commit.
# Get from https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/
# SENTRY_AUTH_TOKEN=

# ─── POSTHOG ───────────────────────────────────────────────────────────────
# Project API token from Project Settings → Project API Key. Bundled into the
# browser by Vite. Also read on the server (CF Workers) for posthog-node
# captures in /api/billing-bridge and /api/extension/sync.
#
# Optional in local dev. Required in production.
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=

# Upstream ingest host. The browser SDK talks to our same-origin `/api/posthog`
# tunnel, which forwards `/e/`, `/flags/`, `/array/`, `/static/`, and related
# PostHog requests to the EU cloud endpoints.
VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
